\newlabel{tab:variants}{{1}{9}{Six task variants. WDBC variants use publicly available data. MIMIC-IV variants require PhysioNet credentials (see Appendix~\ref {app:impacts}). Verdicts: SPS~$\geq 80$ $=$ \textsc {production}, $65 \leq $ SPS~$< 80$ $=$ \textsc {conditional}, SPS~$< 65$ $=$ \textsc {not recommended}~\citep {eniolade2026security}}{table.18}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Reference component scores for all six variants. Each component is in $[0, 1]$, higher is better. FGSM perturbation budget: $\varepsilon = 0.15$ (WDBC) and $\varepsilon = 0.05$ (MIMIC-IV). ECE bins: 10. Boundary attack: 50 starting points, maximum 100 steps, step size 0.05.}}{9}{table.21}\protected@file@percent }
\newlabel{tab:components}{{2}{9}{Reference component scores for all six variants. Each component is in $[0, 1]$, higher is better. FGSM perturbation budget: $\varepsilon = 0.15$ (WDBC) and $\varepsilon = 0.05$ (MIMIC-IV). ECE bins: 10. Boundary attack: 50 starting points, maximum 100 steps, step size 0.05}{table.21}{}}
