\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Per-variant SPS accuracy for Claude and GPT-4.1 across three runs. Mean and population $\sigma $ across three runs. SPS error is mean submitted minus reference SPS. All submissions fall within the $\pm 5$ tolerance band. GPT-4o is excluded because not all variants have three complete submissions.}}{14}{table.43}\protected@file@percent }
\newlabel{tab:pervariant}{{5}{14}{Per-variant SPS accuracy for Claude and GPT-4.1 across three runs. Mean and population $\sigma $ across three runs. SPS error is mean submitted minus reference SPS. All submissions fall within the $\pm 5$ tolerance band. GPT-4o is excluded because not all variants have three complete submissions}{table.43}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Component pass rates across 18 runs per model. A component ``passes'' if the submitted value is within $\pm 0.10$ of the reference value for that variant. For GPT-4o, runs with no submission contribute 0 passes for all four components. The one run with score~0.4 (\texttt  {baseline} run~3) had all four components within $\pm 0.10$ but submitted the wrong weighted sum.}}{14}{table.46}\protected@file@percent }
\newlabel{tab:components2}{{6}{14}{Component pass rates across 18 runs per model. A component ``passes'' if the submitted value is within $\pm 0.10$ of the reference value for that variant. For GPT-4o, runs with no submission contribute 0 passes for all four components. The one run with score~0.4 (\texttt {baseline} run~3) had all four components within $\pm 0.10$ but submitted the wrong weighted sum}{table.46}{}}
